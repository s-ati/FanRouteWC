# Supabase project settings (Project Settings → API)
# Public URL + anon key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, used by the seed script to bypass RLS
# NEVER commit this value or expose it in client bundles
SUPABASE_SERVICE_ROLE_KEY=

# Path to the FanRoute data folder in the Obsidian vault
# Seed script reads venues-san-francisco.md + fixtures-san-francisco.md from here
FANROUTE_DATA_DIR=../Sammy/05-project-notes/fanroute/data

# SerpAPI — primary crowd-data provider (Google Maps engine, place_id lookups)
# Free tier: 250 calls/month. Get key at https://serpapi.com/
SERPAPI_API_KEY=

# Outscraper — fallback crowd-data provider, off by default
# Flip OUTSCRAPER_ENABLED=true if SerpAPI breaks or quota exhausts
OUTSCRAPER_ENABLED=false
OUTSCRAPER_API_KEY=

# Shared secret for /api/cron/* and /api/admin/* endpoints
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=
